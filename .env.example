PROFIT_CHAIN_APP_NAME=Цепочка прибыли
PROFIT_CHAIN_DEBUG=false
PROFIT_CHAIN_GAME_DAY_MINUTES=5
PROFIT_CHAIN_STATE_FILE=.data/game_state.json
PROFIT_CHAIN_DATABASE_URL=sqlite+aiosqlite:///.data/game_state.db
# Зал славы (результаты завершённых партий) хранится отдельно от состояния мира,
# т.к. переживает сброс партии. Без этого пути — только in-memory.
PROFIT_CHAIN_LEADERBOARD_FILE=.data/leaderboard.json
